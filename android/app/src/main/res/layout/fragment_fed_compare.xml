<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Global header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FED MARKETS"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRefresh"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="↻"
                    android:textColor="@color/colorPrimary"
                    android:textSize="18sp"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

            </LinearLayout>

            <!-- ═══════════ INFLATION SECTION ═══════════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="INFLATION"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnInflationInfo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/colorTextSecondary"
                    android:contentDescription="Inflation info" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvInflationScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No data — tap ↻"
                android:textColor="@color/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <com.sun.feddashboard.ui.OverlayChartView
                android:id="@+id/inflationChart"
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginBottom="3dp" />

            <TextView
                android:id="@+id/tvInflationUpdated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/colorTextSecondary"
                android:textSize="10sp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnInflationHD"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="⬇ HD"
                    android:textSize="11sp"
                    app:backgroundTint="@color/colorSurface"
                    app:strokeColor="@color/colorPrimary"
                    app:strokeWidth="1dp"
                    android:textColor="@color/colorPrimary" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/colorDivider"
                android:layout_marginBottom="12dp" />

            <!-- ═══════════ LABOR SECTION ═══════════ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LABOR MARKET"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnLaborInfo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/colorTextSecondary"
                    android:contentDescription="Labor info" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvLaborScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No data — tap ↻"
                android:textColor="@color/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <com.sun.feddashboard.ui.OverlayChartView
                android:id="@+id/laborChart"
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginBottom="3dp" />

            <TextView
                android:id="@+id/tvLaborUpdated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/colorTextSecondary"
                android:textSize="10sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLaborHD"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:text="⬇ HD"
                android:textSize="11sp"
                app:backgroundTint="@color/colorSurface"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="1dp"
                android:textColor="@color/colorPrimary" />

            <!-- NEXT DATA RELEASES card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NEXT DATA RELEASES  ·  ISI / LSI"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvDataSources"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorText"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.55"
                        android:text="Loading…" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
