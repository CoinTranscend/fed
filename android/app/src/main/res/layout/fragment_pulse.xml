<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PULSE"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="People's Underlying Living Stress Engine"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.04" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/btnInfo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/colorTextSecondary"
                    android:contentDescription="Info" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRefresh"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="↻"
                    android:textColor="@color/colorSecondary"
                    android:textSize="18sp"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

            </LinearLayout>

            <!-- Main composite score -->
            <TextView
                android:id="@+id/tvScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No data — tap ↻"
                android:textColor="@color/colorSecondary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp" />

            <!-- Regime description -->
            <TextView
                android:id="@+id/tvRegimeDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginBottom="8dp" />

            <!-- Sub-index scores row (EIP / ASI / FSS) -->
            <LinearLayout
                android:id="@+id/layoutSubScores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <!-- EIP -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/colorSurface"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EIP"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvEip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Essentials"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="8sp" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/colorDivider"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />

                <!-- ASI -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/colorSurface"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ASI"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAsi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Credit/Savings"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="8sp" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/colorDivider"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />

                <!-- FSS -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/colorSurface"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FSS"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.1"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvFss"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Forward Signal"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="8sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Chart — fixed height, always rendered, never squished -->
            <com.sun.feddashboard.ui.OverlayChartView
                android:id="@+id/chart"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginBottom="4dp" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/tvUpdated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/colorTextSecondary"
                android:textSize="10sp"
                android:layout_marginBottom="10dp" />

            <!-- AI Narrative card — always auto-fetched; shown when ready -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNarrative"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="AI NARRATIVE  ·  Consumer Stress Analysis"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="10sp"
                            android:letterSpacing="0.06" />

                        <ProgressBar
                            android:id="@+id/progressGemini"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:visibility="gone" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNarrative"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorText"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom button: 30-year chart export -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDownloadHD"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="⬇ 30-Year Chart"
                android:textSize="11sp"
                app:backgroundTint="@color/colorSurface"
                app:strokeColor="@color/colorSecondary"
                app:strokeWidth="1dp"
                android:textColor="@color/colorSecondary" />

            <!-- FRED data sources card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NEXT DATA RELEASES  ·  PULSE"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvDataSources"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorText"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.55"
                        android:text="Loading…" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
