<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RECESSION RISK"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnInfo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_info_details"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/colorTextSecondary"
                android:contentDescription="Info" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRefresh"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="↻"
                android:textColor="@color/colorPrimary"
                android:textSize="18sp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

        </LinearLayout>

        <!-- Score -->
        <TextView
            android:id="@+id/tvScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading…"
            android:textColor="@color/colorPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <!-- Regime description -->
        <TextView
            android:id="@+id/tvRegimeDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:layout_marginBottom="6dp" />

        <!-- Chart -->
        <com.sun.feddashboard.ui.OverlayChartView
            android:id="@+id/chart"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="4dp" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvUpdated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextSecondary"
            android:textSize="10sp"
            android:layout_marginBottom="8dp" />

        <!-- AI Analysis card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardNarrative"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AI ANALYSIS  ·  Gemini + Google Search"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.06" />

                    <ProgressBar
                        android:id="@+id/progressGemini"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:visibility="gone" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvNarrative"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorText"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Buttons row 1: AI + HD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAiAnalysis"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="✦ AI Analysis"
                android:textSize="11sp"
                app:backgroundTint="@color/colorSurface"
                app:strokeColor="@color/colorSecondary"
                app:strokeWidth="1dp"
                android:textColor="@color/colorSecondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDownloadHD"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="⬇ HD Chart"
                android:textSize="11sp"
                app:backgroundTint="@color/colorSurface"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="1dp"
                android:textColor="@color/colorPrimary" />

        </LinearLayout>

        <!-- Buttons row 2: 30-year history export -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownload30Y"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="⬇ 30-Year History Chart  (with NBER recessions)"
            android:textSize="11sp"
            app:backgroundTint="@color/colorSurface"
            app:strokeColor="@color/colorTextSecondary"
            app:strokeWidth="1dp"
            android:textColor="@color/colorTextSecondary" />

    </LinearLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
