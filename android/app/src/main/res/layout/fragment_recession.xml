<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RECESSION RISK"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnInfo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_info_details"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/colorTextSecondary"
                android:contentDescription="Info" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRefresh"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="↻"
                android:textColor="@color/colorPrimary"
                android:textSize="18sp"
                android:minWidth="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

        </LinearLayout>

        <!-- Score -->
        <TextView
            android:id="@+id/tvScore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading…"
            android:textColor="@color/colorPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <!-- Regime description -->
        <TextView
            android:id="@+id/tvRegimeDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:layout_marginBottom="6dp" />

        <!-- Chart -->
        <com.sun.feddashboard.ui.OverlayChartView
            android:id="@+id/chart"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="4dp" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvUpdated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextSecondary"
            android:textSize="10sp"
            android:layout_marginBottom="8dp" />

        <!-- DOS terminal countdown clock — tap to view full AI analysis -->
        <LinearLayout
            android:id="@+id/clockContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:orientation="vertical"
            android:background="#0D0D0D"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tvClockLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="> RECESSION RISK COUNTDOWN_"
                android:textColor="#00FF41"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvClockTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="---:--"
                android:textColor="#00FF41"
                android:textSize="36sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvClockUnits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DAYS · HRS"
                android:textColor="#00C030"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.2"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00B020"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:visibility="gone" />

        </LinearLayout>


<!-- Buttons row 1: AI + HD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAiAnalysis"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="✦ AI Analysis"
                android:textSize="11sp"
                app:backgroundTint="@color/colorSurface"
                app:strokeColor="@color/colorSecondary"
                app:strokeWidth="1dp"
                android:textColor="@color/colorSecondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDownloadHD"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="⬇ HD Chart"
                android:textSize="11sp"
                app:backgroundTint="@color/colorSurface"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="1dp"
                android:textColor="@color/colorPrimary" />

        </LinearLayout>

        <!-- Buttons row 2: 30-year history export -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownload30Y"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="⬇ 30-Year History Chart  (with NBER recessions)"
            android:textSize="11sp"
            app:backgroundTint="@color/colorSurface"
            app:strokeColor="@color/colorTextSecondary"
            app:strokeWidth="1dp"
            android:textColor="@color/colorTextSecondary" />

    </LinearLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
