<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HPulse"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Household Pulse Index  ·  0–100 stress score"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.04" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/btnInfo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/colorTextSecondary"
                    android:contentDescription="Info" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRefresh"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="↻"
                    android:textColor="@color/colorSecondary"
                    android:textSize="18sp"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

            </LinearLayout>

            <!-- Composite score -->
            <TextView
                android:id="@+id/tvCompositeScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No data — tap ↻"
                android:textColor="@color/colorSecondary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp" />

            <!-- Band description -->
            <TextView
                android:id="@+id/tvBandDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginBottom="8dp" />

            <!-- Tier score cards row: Burn | Middle | Buffer -->
            <LinearLayout
                android:id="@+id/layoutTierScores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <!-- Burn Zone -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/colorSurface"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BURN ZONE"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="8sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBurnScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="≤ $65 k/yr"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="8sp" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/colorDivider"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />

                <!-- Middle Pulse -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/colorSurface"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MIDDLE PULSE"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="8sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMiddleScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$65–105 k/yr"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="8sp" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/colorDivider"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />

                <!-- Buffer Zone -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/colorSurface"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BUFFER ZONE"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="8sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBufferScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$105–175 k/yr"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="8sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- HPulse chart — fixed height, 3 tier lines, 0-100 scale -->
            <com.sun.feddashboard.ui.HPulseChartView
                android:id="@+id/hpulseChart"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginBottom="4dp" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/tvUpdated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/colorTextSecondary"
                android:textSize="10sp"
                android:layout_marginBottom="10dp" />

            <!-- AI Narrative card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNarrative"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="AI NARRATIVE  ·  Household Stress Analysis"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="10sp"
                            android:letterSpacing="0.06" />

                        <ProgressBar
                            android:id="@+id/progressGemini"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:visibility="gone" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNarrative"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorText"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 30-year export button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDownloadHD"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="⬇ 30-Year Chart"
                android:textSize="11sp"
                app:backgroundTint="@color/colorSurface"
                app:strokeColor="@color/colorSecondary"
                app:strokeWidth="1dp"
                android:textColor="@color/colorSecondary" />

            <!-- FRED data sources card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DATA RELEASES  ·  HPulse  (last release  →  next)"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="10sp"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvDataSources"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorText"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.55"
                        android:text="Loading…" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
